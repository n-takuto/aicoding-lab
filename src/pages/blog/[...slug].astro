---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = (await getCollection('blog')).sort((a, b) => {
		const dateDiff = a.data.pubDate.valueOf() - b.data.pubDate.valueOf();
		if (dateDiff !== 0) return dateDiff;
		// 同日付の場合はファイル名（id）で安定ソート
		return a.id.localeCompare(b.id);
	});
	return posts.map((post, index) => ({
		params: { slug: post.id },
		props: {
			post,
			prevPost: index > 0 ? posts[index - 1] : null,
			nextPost: index < posts.length - 1 ? posts[index + 1] : null,
		},
	}));
}

type Props = {
	post: CollectionEntry<'blog'>;
	prevPost: CollectionEntry<'blog'> | null;
	nextPost: CollectionEntry<'blog'> | null;
};

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await render(post);
---

<BlogPost {...post.data} prevPost={prevPost} nextPost={nextPost}>
	<Content />
</BlogPost>
