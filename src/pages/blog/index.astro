---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="ja">
	<head>
		<BaseHead title={`Blog - ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 860px;
				max-width: calc(100% - 2em);
				margin: 0 auto;
				padding: 3em 1em;
			}
			.page-title {
				font-size: 2em;
				margin-bottom: 1em;
				text-align: center;
			}
			.article-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
				gap: 1.5em;
			}
			.article-card {
				display: block;
				padding: 1.5em;
				background-color: white;
				border-radius: 12px;
				border: 1px solid rgb(var(--gray-light));
				text-decoration: none;
				color: inherit;
				transition: all 0.2s ease;
			}
			.article-card:hover {
				transform: translateY(-3px);
				box-shadow: 0 8px 24px rgba(var(--gray), 0.15);
				border-color: var(--accent);
			}
			.article-date {
				color: rgb(var(--gray));
				font-size: 0.9em;
				margin: 0 0 0.5em;
			}
			.article-title {
				font-size: 1.15em;
				margin: 0 0 0.75em;
				color: rgb(var(--black));
				line-height: 1.4;
			}
			.article-desc {
				font-size: 0.95em;
				color: rgb(var(--gray-dark));
				margin: 0 0 1em;
				line-height: 1.5;
				display: -webkit-box;
				-webkit-line-clamp: 3;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}
			.article-readmore {
				color: var(--accent);
				font-weight: 600;
				font-size: 0.95em;
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1 class="page-title">📝 Blog</h1>
			<div class="article-grid">
				{
					posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="article-card">
							<p class="article-date">
								<FormattedDate date={post.data.pubDate} />
							</p>
							<h3 class="article-title">{post.data.title}</h3>
							<p class="article-desc">{post.data.description}</p>
							<span class="article-readmore">続きを読む →</span>
						</a>
					))
				}
			</div>
		</main>
		<Footer />
	</body>
</html>
