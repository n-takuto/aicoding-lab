{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/verify-reminder.cjs"
          },
          {
            "type": "command",
            "command": "node .claude/hooks/check-blog-dates.cjs"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "PowerShell(Get-ChildItem*)",
      "PowerShell(Get-Content*)",
      "PowerShell(Get-Command*)",
      "PowerShell(Get-NetTCPConnection*)",
      "PowerShell(Test-Path*)",
      "PowerShell(Resolve-DnsName*)",
      "PowerShell(nslookup*)",
      "PowerShell(Start-Sleep*)",
      "PowerShell(dir*)",
      "PowerShell(ls*)",
      "PowerShell(where.exe*)",
      "PowerShell(node --version*)",
      "PowerShell(npm --version*)",
      "PowerShell(git --version*)",
      "PowerShell(winget --version*)"
    ]
  }
}
